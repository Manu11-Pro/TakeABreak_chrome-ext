{
  "manifest_version": 3,
  "name": "Take A Break!",
  "version": "1.0",
  "description": "Reminds you to take a break!.",
  "icons":
  {"128": "icon128.png"},
  "permissions": ["alarms", "notifications"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}